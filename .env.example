NODE_ENV=production
PORT=3847

# Use this for Railway Volume or any VPS persistent directory.
# Railway example: mount a Volume and set DATA_DIR=/data
DATA_DIR=.data

# Telegram bot. Never commit real tokens.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_BOT_COMMANDS=true
TELEGRAM_MIN_AMOUNT=40
TELEGRAM_BATCH_LIMIT=5
# Optional comma list, e.g. apucash,paidcash
TELEGRAM_SOURCES=

# Private cookies. Prefer environment variables on Railway/VPS.
APUCASH_COOKIE=
SPLITDROP_COOKIE=
REVNO_COOKIE=
